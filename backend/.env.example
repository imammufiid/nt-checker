# Anthropic API key (required) — get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Server port
PORT=3000

# Path to SQLite database file
DATABASE_PATH=./data.sqlite

# Claude model. Options:
#   claude-opus-4-7        (best quality, most expensive)
#   claude-sonnet-4-6      (recommended — good balance)
#   claude-haiku-4-5-20251001  (cheapest, fastest)
CLAUDE_MODEL=claude-sonnet-4-6

# --- Auth (M1) ---
# Required-at-boot signing keys. MUST be different from each other.
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token TTLs (seconds). Defaults per SEC-001: 15 min access, 7 days refresh.
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# Bcrypt cost. SEC-001 requires >= 10; 12 gives some headroom.
BCRYPT_COST=12

# Set to 1 on the first boot after upgrading from MVP to seed a "legacy" user
# and assign existing scans to it. Idempotent; safe to leave on but typically
# only needed once.
RUN_LEGACY_BACKFILL=0
